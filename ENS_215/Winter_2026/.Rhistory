# load in tidyverse and groundwater data
library(tidyverse)
bangladesh_gw <- read_csv("https://stahlm.github.io/ENS_215/Data/NationalSurveyData_DPHE_BGS_LabData.csv")
# summary of well depth catagorized in three depth groups
bangladesh_gw <- mutate(bangladesh_gw,
depth_cat = case_when(WELL_DEPTH_m <= 50 ~ "shallow",
WELL_DEPTH_m > 50 & WELL_DEPTH_m <= 100 ~ "intermediate",
WELL_DEPTH_m > 100 ~ "deep"
)
)
# creates levels for each depth cat
bangladesh_gw$depth_cat <- factor(bangladesh_gw$depth_cat,
levels = c("shallow", "intermediate", "deep"),
ordered = TRUE)
bangladesh_gw <- mutate(bangladesh_gw,
as_cat = case_when(
As_ugL <= 10 ~ "low",
As_ugL > 10 & As_ugL <= 50 ~ "med",
As_ugL > 50 ~ "high"
)
)
bangladesh_gw$as_cat <- factor(bangladesh_gw$as_cat,
levels = c("low", "med", "high"),
ordered = TRUE)
# summary table of mean and median of Well depth, well construction year, arsenic, iron, manganese, and sulfate
t1 <- summarise(bangladesh_gw,
mean_depth = mean(WELL_DEPTH_m, na.rm = T),
median_depth = median(WELL_DEPTH_m, na.rm = T),
mean_year = mean(YEAR_CONSTRUCTION, na.rm = T),
median_year = median(YEAR_CONSTRUCTION, na.rm = T),
mean_arsenic = mean(As_ugL, na.rm = T),
median_arsenic = median(As_ugL, na.rm = T),
mean_iron = mean(Fe_mgL, na.rm = T),
median_iron = median(Fe_mgL, na.rm = T),
mean_mn = mean(Mn_mgL, na.rm = T),
median_mn = median(Mn_mgL, na.rm = T),
mean_so = mean(SO4_mgL, na.rm = T),
median_so = median(SO4_mgL, na.rm = T)
)
t1
t1 <- bangladesh_gw %>%
group_by(DIVISION)%>% # same table as above grouped by division
summarise(mean_depth = mean(WELL_DEPTH_m, na.rm = T),
median_depth = median(WELL_DEPTH_m, na.rm = T),
mean_year = mean(YEAR_CONSTRUCTION, na.rm = T),
median_year = median(YEAR_CONSTRUCTION, na.rm = T),
mean_arsenic = mean(As_ugL, na.rm = T),
median_arsenic = median(As_ugL, na.rm = T),
mean_iron = mean(Fe_mgL, na.rm = T),
median_iron = median(Fe_mgL, na.rm = T),
mean_mn = mean(Mn_mgL, na.rm = T),
median_mn = median(Mn_mgL, na.rm = T),
mean_so = mean(SO4_mgL, na.rm = T),
median_so = median(SO4_mgL, na.rm = T)
)%>%
arrange(desc(mean_arsenic)) # and sorted in descending order by mean arsenic
t1
# distribution of low, medium, and high arsenic wells by division
table_exposure <- bangladesh_gw %>%
group_by(DIVISION)%>%
summarise(n_wells = n(),
percent_low_As = sum(as_cat == "low")/n_wells,
percent_medium_As = sum(as_cat == "med")/n_wells,
percent_high_As = sum(as_cat == "high")/n_wells
)
table_exposure
#distribution of low, medium, and high arsenic wells by depth category
