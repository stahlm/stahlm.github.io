group_by(depth_cat)%>%
summarise(n_wells = n(),
percent_low_As = sum(as_cat == "low")/n_wells,
percent_medium_As = sum(as_cat == "med")/n_wells,
percent_high_As = sum(as_cat == "high")/n_wells
)
table_exposure2
