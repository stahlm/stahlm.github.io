library(tidyverse)
bangladesh_gw <- read_csv("https://stahlm.github.io/ENS_215/Data/NationalSurveyData_DPHE_BGS_LabData.csv")
bangladesh_gw <- bangladesh_gw %>%
mutate(
depth_cat = case_when( WELL_DEPTH_m <= 50 ~ "shallow",
WELL_DEPTH_m > 50 & WELL_DEPTH_m <= 100 ~ "intermed",
WELL_DEPTH_m > 100 ~ "deep"))
bangladesh_gw
bangladesh_gw <- bangladesh_gw%>%
mutate(depth_cat = factor(bangladesh_gw$depth_cat, levels = c("shallow", "intermed", "deep"), ordered = TRUE))
bangladesh_gw <- bangladesh_gw %>%
mutate( As_cat = case_when( As_ugL <= 10 ~ "low",
As_ugL > 10 & As_ugL <=50 ~ "med",
As_ugL > 50 ~ "high")) %>%
mutate(As_cat = factor(As_cat, levels = c("low", "med", "high"), ordered = TRUE))
Summary_1 <- summarise(bangladesh_gw,
avg_depth = mean(WELL_DEPTH_m, na.rm=T),
med_depth = median(WELL_DEPTH_m, na.rm=T),
avg_year_built = mean(YEAR_CONSTRUCTION, na.rm=T),
med_year_built = median(YEAR_CONSTRUCTION, na.rm=T),
avg_As = mean(As_ugL, na.rm=T),
med_As = median(As_ugL, na.rm=T),
avg_Fe = mean(Fe_mgL, na.rm=T),
med_Fe = median(Fe_mgL, na.rm=T),
avg_Mn = mean(Mn_mgL, na.rm=T),
med_Mn = median(Mn_mgL, na.rm=T),
avg_SO4 = mean(SO4_mgL, na.rm=T),
med_SO4 = median(SO4_mgL, na.rm=T),
)
Summary_1
library(tidyverse)
library(tmap)
library(sf)
borders_hires <- rnaturalearth::ne_countries(country = "Switzerland",
scale = "large",
returnclass = "sf")
catalog %>%
filter(id == "terraclim") %>%
select(varname, units, description)
climate_raster <- getTerraClim(
AOI = borders_hires,
varname = "ppt",
startDate = "2021-01-01",
endDate = "2021-12-01",
verbose = T,
dryrun = FALSE
)
library(tidyverse)
library(tmap)
library(sf)
library(climateR)
borders_hires <- rnaturalearth::ne_countries(country = "Switzerland",
scale = "large",
returnclass = "sf")
catalog %>%
filter(id == "terraclim") %>%
select(varname, units, description)
climate_raster <- getTerraClim(
AOI = borders_hires,
varname = "ppt",
startDate = "2021-01-01",
endDate = "2021-12-01",
verbose = T,
dryrun = FALSE
)
climate_raster <- climate_raster$ppt
climate_raster <- terra::crop(climate_raster, borders_hires)
climate_raster <- terra::mask(climate_raster, borders_hires)
switzerland_tot_prcp <- sum(climate_raster)
terra::plot(switzerland_tot_prcp)
switzerland_mean_prcp <- mean(climate_raster)
library(elevatr)
